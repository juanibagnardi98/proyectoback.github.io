<%- include('partials/header') %>

<section class="page-header">
  <h1>Carrito <%= cart._id %></h1>
</section>

<% if (!cart.products.length) { %>
  <p>El carrito está vacío.</p>
<% } else { %>
  <table class="cart-table">
    <thead>
      <tr>
        <th>Producto</th>
        <th>Precio</th>
        <th>Cantidad</th>
        <th>Subtotal</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% cart.products.forEach(item => { %>
        <tr>
          <td><a href="/products/<%= item.product._id %>"><%= item.product.title %></a></td>
          <td>$<%= item.product.price %></td>
          <td><%= item.quantity %></td>
          <td>$<%= item.quantity * item.product.price %></td>
          <td>
            <button class="button remove-from-cart" data-product="<%= item.product._id %>">Eliminar</button>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
  <button class="button empty-cart" data-cart="<%= cart._id %>">Vaciar carrito</button>
<% } %>

<script>
  document.querySelectorAll('.remove-from-cart').forEach(button => {
    button.addEventListener('click', async () => {
      const cartId = '<%= cart._id %>';
      const productId = button.getAttribute('data-product');
      await fetch(`/api/carts/${cartId}/products/${productId}`, { method: 'DELETE' });
      window.location.reload();
    });
  });

  const emptyButton = document.querySelector('.empty-cart');
  if (emptyButton) {
    emptyButton.addEventListener('click', async () => {
      const cartId = '<%= cart._id %>';
      await fetch(`/api/carts/${cartId}`, { method: 'DELETE' });
      window.location.reload();
    });
  }
</script>

<%- include('partials/footer') %>
